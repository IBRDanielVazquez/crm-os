{
  "name": "crm-os",
  "version": "1.0.0",
  "description": "Multi-tenant SaaS Platform (HighLevel Style)",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "build": "npm run build --workspaces --if-present",
    "db:migrate": "npm run migrate --workspace @crm-os/database",
    "db:studio": "npm run studio --workspace @crm-os/database"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "prisma": "^7.8.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@prisma/client": "^7.8.0",
    "zod": "^4.3.6"
  }
}
